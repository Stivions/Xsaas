NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# X OAuth
X_CLIENT_ID=
X_REDIRECT_URI=http://localhost:3000/api/x/connect/callback
