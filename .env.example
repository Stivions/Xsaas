NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
# Use a dedicated database for Xsaas. Do not point this app at another project's database.
MONGODB_URI=mongodb://127.0.0.1:27017/xsaas
JWT_SECRET=change-me
ENCRYPTION_SECRET=change-me
COOKIE_NAME=xsaas_token
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AUTOMATION_ENABLED=true
AUTOMATION_TICK_MS=60000
AUTOMATION_DEFAULT_CADENCE_MINUTES=180
GOOGLE_TRENDS_GEO=US
GOOGLE_NEWS_HL=en-US
GOOGLE_NEWS_GL=US
GOOGLE_NEWS_CEID=US:en

X_BASE_URL=https://x.com
X_HEADLESS=true
X_CONNECT_TIMEOUT_MS=900000
# Optional only if you still want official OAuth experiments. Browser-session mode does not require these.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/x/connect/callback
X_SCOPES=tweet.read tweet.write users.read offline.access

PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_STARTER_PLAN_ID=
PAYPAL_PRO_PLAN_ID=
PAYPAL_AGENCY_PLAN_ID=
